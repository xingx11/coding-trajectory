# Coding Trajectory Pipeline - Environment Variables
# Copy this file to .env and fill in your real tokens.
# NEVER commit .env to version control.

# Scaffold version requirement (see scripts/setup_scaffold.sh)
# Required: @anthropic-ai/claude-code@2.1.86
# Install: npm install -g @anthropic-ai/claude-code@2.1.86
# Disable auto-update to prevent version drift:
DISABLE_AUTOUPDATER=1

# Qwen endpoint (公网访问 qwen 3.7 max)
QWEN_AUTH_TOKEN=<your-qwen-token>
QWEN_BASE_URL=<your-qwen-base-url>
QWEN_MODEL=qwen3.7-max

# Claude endpoint
CLAUDE_AUTH_TOKEN=<your-claude-token>
CLAUDE_BASE_URL=<your-claude-base-url>
CLAUDE_MODEL=claude-opus-4-6-20260205

# GitHub (optional, recommended for gen command)
# Without token: 10 search requests/min; with token: 30/min
# Create at https://github.com/settings/tokens (no scopes needed for public repo search)
GITHUB_TOKEN=

# Gitee (required for gen --source gitee, search API needs authentication)
# Create at https://gitee.com/personal_access_tokens
GITEE_TOKEN=

# HTTP Proxy (optional, required in China mainland for GitHub access)
# Used by both GitHub API search and git clone
# Example: http://127.0.0.1:7897
HTTP_PROXY=

# OpenTelemetry / otel-claude-hook (optional)
# These variables are forwarded to claude subprocesses for telemetry collection.
OTEL_EXPORTER_OTLP_ENDPOINT=<your-otlp-endpoint>
OTEL_RESOURCE_ATTRIBUTES=<your-resource-attributes>
CLAUDE_CODE_ENABLE_TELEMETRY=1
NODE_OPTIONS=--require ~/.cache/opentelemetry.instrumentation.claude/intercept.js
